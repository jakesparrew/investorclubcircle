// InvestorClub Platform — Prisma schema
// Phase 1 (Fundament). See docs/superpowers/specs/2026-06-15-platform-design.md §5.1.
// Money is stored as integers in minor units (cents). Currency defaults to "eur".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (CLI) and are passed to
  // PrismaClient via `datasourceUrl` at runtime (see src/lib/db.ts).
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  MEMBER
  EXPERT
  ADMIN
}

enum MembershipStatus {
  active
  trialing
  past_due
  canceled
  incomplete
}

enum BillingInterval {
  month
  year
}

enum OrderStatus {
  pending
  paid
  refunded
}

enum OfferKind {
  order_bump
  upsell
  downsell
}

enum OfferTrigger {
  tier
  product
  checkout
}

enum GiftStatus {
  purchased
  redeemed
  expired
}

enum PromotionKind {
  PERCENT
  AMOUNT
  TRIAL
  INTRO
}

enum DurationType {
  ONCE
  REPEATING
  FOREVER
}

enum AffiliateStatus {
  active
  paused
}

enum ReferralType {
  signup
  subscription
  order
  course
}

enum RewardKind {
  free_month
  credit
  cash
}

enum RewardStatus {
  pending
  approved
  paid
}

enum PaymentKind {
  subscription
  one_time
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum DunningOutcome {
  pending
  recovered
  failed
}

// ─── Organization (light multi-tenant hook; one row for now) ────────────────

model Organization {
  id                       String   @id @default(cuid())
  name                     String
  stripeConnectedAccountId String?
  stripeAccountStatus      String?
  defaultCurrency          String   @default("eur")
  createdAt                DateTime @default(now())

  tiers       Tier[]
  memberships Membership[]
  products    Product[]
  bundles     Bundle[]
  offers      Offer[]
  promotions  Promotion[]
  memberTags  MemberTag[]
  spaceGroups SpaceGroup[]
  levels      Level[]
  events      Event[]
  eventSeries EventSeries[]
  courses     Course[]
  livestreams Livestream[]
  newsletters NewsletterIssue[]
}

// ─── Auth.js models (required by @auth/prisma-adapter) ──────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  suspendedUntil DateTime?
  createdAt     DateTime  @default(now())

  accounts            Account[]
  sessions            Session[]
  memberships         Membership[]
  orders              Order[]
  payments            Payment[]
  giftsPurchased      Gift[]               @relation("GiftPurchaser")
  giftsRedeemed       Gift[]               @relation("GiftRedeemed")
  affiliate           Affiliate?
  referralsAsReferred ReferralConversion[] @relation("ReferredUser")
  tags                UserTag[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  onboarding          UserOnboardingProgress[]

  // Community (Fase 2)
  profile       Profile?
  posts         Post[]
  comments      Comment[]
  reactions     Reaction[]
  pollVotes     PollVote[]
  bookmarks     Bookmark[]
  notifications Notification[]
  reports       Report[]
  points        PointsLedger[]
  badges        UserBadge[]

  // Events (Fase 4)
  eventsHosted  Event[]        @relation("EventHost")
  registrations Registration[]

  // Academy (Fase 6)
  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  certificates   Certificate[]

  // Chat (Fase 3)
  conversationMemberships ConversationMember[]
  messages                Message[]

  // Content (Fase 5)
  newsletterOptIn Boolean      @default(false)
  streamsHosted   Livestream[] @relation("StreamHost")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Membership, tiers & access ─────────────────────────────────────────────

model Tier {
  id                  String   @id @default(cuid())
  orgId               String
  key                 String // free | basis | premium
  name                String
  description         String?
  priceMonthly        Int? // cents
  priceYearly         Int? // cents
  currency            String   @default("eur")
  stripeProductId     String?
  stripePriceMonthlyId String?
  stripePriceYearlyId String?
  perks               Json?
  sortOrder           Int      @default(0)
  active              Boolean  @default(true)

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships Membership[]
  gifts       Gift[]

  @@unique([orgId, key])
  @@index([orgId])
}

model Membership {
  id                   String           @id @default(cuid())
  userId               String
  orgId                String
  tierId               String
  status               MembershipStatus @default(incomplete)
  interval             BillingInterval?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  grandfathered        Boolean          @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?          @unique
  startedAt            DateTime         @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tier            Tier             @relation(fields: [tierId], references: [id])
  dunningAttempts DunningAttempt[]

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([stripeCustomerId])
}

// ─── One-time sales: products, prices, bundles, offers, orders, gifts ───────

model Product {
  id              String   @id @default(cuid())
  orgId           String
  name            String
  description     String?
  active          Boolean  @default(true)
  stripeProductId String?
  images          String[]
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  prices Price[]
  orders Order[]

  @@index([orgId])
}

model Price {
  id            String  @id @default(cuid())
  productId     String
  amount        Int // cents
  currency      String  @default("eur")
  stripePriceId String?
  active        Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]
  offers  Offer[] @relation("OfferPrice")

  @@index([productId])
}

model Bundle {
  id            String  @id @default(cuid())
  orgId         String
  name          String
  description   String?
  items         Json // { productIds: string[], tierIds: string[] }
  price         Int // cents
  currency      String  @default("eur")
  stripePriceId String?
  active        Boolean @default(true)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([orgId])
}

model Offer {
  id             String       @id @default(cuid())
  orgId          String
  kind           OfferKind
  triggerType    OfferTrigger
  triggerRef     String? // tierId / productId / "checkout"
  offeredPriceId String
  discountPercent Int?
  active         Boolean      @default(true)

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  offeredPrice Price        @relation("OfferPrice", fields: [offeredPriceId], references: [id])

  @@index([orgId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  productId             String?
  bundleId              String?
  priceId               String?
  amount                Int // cents
  currency              String      @default("eur")
  applicationFeeAmount  Int? // cents (platform commission)
  status                OrderStatus @default(pending)
  stripeCheckoutSessionId String?   @unique
  stripePaymentIntentId String?
  createdAt             DateTime    @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  bundle  Bundle?  @relation(fields: [bundleId], references: [id])
  price   Price?   @relation(fields: [priceId], references: [id])

  @@index([userId])
}

model Gift {
  id                    String     @id @default(cuid())
  purchaserId           String
  tierId                String
  interval              BillingInterval
  redemptionCode        String     @unique
  redeemedByUserId      String?
  redeemedAt            DateTime?
  status                GiftStatus @default(purchased)
  stripePaymentIntentId String?
  createdAt             DateTime   @default(now())

  purchaser  User  @relation("GiftPurchaser", fields: [purchaserId], references: [id])
  redeemedBy User? @relation("GiftRedeemed", fields: [redeemedByUserId], references: [id])
  tier       Tier  @relation(fields: [tierId], references: [id])

  @@index([purchaserId])
}

// ─── Promotions, affiliates, payments, dunning ──────────────────────────────

model Promotion {
  id                  String       @id @default(cuid())
  orgId               String
  code                String
  kind                PromotionKind
  value               Int? // percent (0-100) or amount in cents, depending on kind
  currency            String?
  durationType        DurationType @default(ONCE)
  durationMonths      Int?
  appliesToTiers      String[]
  maxRedemptions      Int?
  timesRedeemed       Int          @default(0)
  expiresAt           DateTime?
  stripeCouponId      String?
  stripePromotionCodeId String?
  active              Boolean      @default(true)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, code])
  @@index([orgId])
}

model Affiliate {
  id               String          @id @default(cuid())
  userId           String          @unique
  code             String          @unique
  commissionPercent Int            @default(0)
  status           AffiliateStatus @default(active)
  createdAt        DateTime        @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversions ReferralConversion[]
}

model ReferralConversion {
  id              String       @id @default(cuid())
  affiliateId     String
  referredUserId  String
  type            ReferralType
  rewardKind      RewardKind   @default(free_month)
  rewardAmount    Int?
  rewardStatus    RewardStatus @default(pending)
  stripeTransferId String?
  createdAt       DateTime     @default(now())

  affiliate    Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUser User      @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@index([affiliateId])
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  kind                  PaymentKind
  amount                Int // cents
  currency              String        @default("eur")
  applicationFeeAmount  Int? // cents
  stripeInvoiceId       String?
  stripePaymentIntentId String?
  status                PaymentStatus @default(pending)
  createdAt             DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DunningAttempt {
  id            String         @id @default(cuid())
  membershipId  String
  attemptNumber Int
  channel       String         @default("email")
  sentAt        DateTime       @default(now())
  outcome       DunningOutcome @default(pending)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId])
}

// ─── Member tags / segmentation ─────────────────────────────────────────────

model MemberTag {
  id    String  @id @default(cuid())
  orgId String
  name  String
  color String?

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users UserTag[]

  @@unique([orgId, name])
  @@index([orgId])
}

model UserTag {
  userId     String
  tagId      String
  assignedAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  MemberTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@index([tagId])
}

// ─── Onboarding (welcome checklist) ─────────────────────────────────────────

model OnboardingStep {
  id        String  @id @default(cuid())
  orgId     String
  key       String
  title     String
  sortOrder Int     @default(0)
  required  Boolean @default(false)

  @@unique([orgId, key])
}

model UserOnboardingProgress {
  id          String   @id @default(cuid())
  userId      String
  stepKey     String
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stepKey])
  @@index([userId])
}

// ─── Infrastructure: webhook idempotency + audit log ────────────────────────

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
}

// ─── Community (Fase 2) ─────────────────────────────────────────────────────

model Profile {
  userId    String   @id
  bio       String?
  headline  String?
  expertise String[]
  links     Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpaceGroup {
  id        String  @id @default(cuid())
  orgId     String
  name      String
  sortOrder Int     @default(0)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  spaces Space[]

  @@index([orgId])
}

model Space {
  id           String  @id @default(cuid())
  spaceGroupId String
  name         String
  slug         String  @unique
  description  String?
  isPublic     Boolean @default(false)
  minTier      String? // null | free | basis | premium
  sortOrder    Int     @default(0)

  group SpaceGroup @relation(fields: [spaceGroupId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([spaceGroupId])
}

model Post {
  id        String    @id @default(cuid())
  spaceId   String
  authorId  String
  title     String?
  content   String
  pinned    Boolean   @default(false)
  hiddenAt  DateTime?
  createdAt DateTime  @default(now())

  space    Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  poll     Poll?

  @@index([spaceId])
  @@index([authorId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  hiddenAt  DateTime?
  createdAt DateTime  @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
}

model Reaction {
  id         String   @id @default(cuid())
  targetType String // "post" | "comment"
  targetId   String
  userId     String
  type       String   @default("like")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId, type])
  @@index([targetType, targetId])
}

model Poll {
  id            String       @id @default(cuid())
  postId        String       @unique
  question      String
  allowMultiple Boolean      @default(false)
  closesAt      DateTime?

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options PollOption[]
}

model PollOption {
  id        String @id @default(cuid())
  pollId    String
  text      String
  sortOrder Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id           String   @id @default(cuid())
  pollOptionId String
  userId       String
  createdAt    DateTime @default(now())

  option PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollOptionId, userId])
  @@index([pollOptionId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  targetType String // post | lesson | event
  targetId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ─── Gamification (Fase 2) ──────────────────────────────────────────────────

model PointsLedger {
  id         String   @id @default(cuid())
  userId     String
  points     Int
  reason     String
  sourceType String?
  sourceId   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Level {
  id        String @id @default(cuid())
  orgId     String
  rank      Int
  name      String
  minPoints Int

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, rank])
}

model Badge {
  id    String  @id @default(cuid())
  key   String  @unique
  name  String
  icon  String?

  users UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([badgeId])
}

// ─── Events & ticketbalie (Fase 4) ──────────────────────────────────────────

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum RegistrationType {
  deposit
  paid
  free
}

enum RegistrationStatus {
  pending
  confirmed
  waitlisted
  cancelled
  refunded
}

model EventSeries {
  id             String   @id @default(cuid())
  orgId          String
  recurrenceRule String
  createdAt      DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  events Event[]
}

model Event {
  id              String      @id @default(cuid())
  orgId           String
  seriesId        String?
  hostId          String
  title           String
  slug            String      @unique
  description     String?
  location        String?
  startsAt        DateTime
  endsAt          DateTime?
  capacity        Int?
  softCap         Int?
  isPublic        Boolean     @default(false)
  minTier         String?
  depositAmount   Int? // cents — refundable member no-show deposit (e.g. 100 = €1)
  nonMemberPrice  Int? // cents — paid ticket for non-members
  recurrenceRule  String?
  reminderOffsets Int[]
  status          EventStatus @default(draft)
  recordingUrl    String?
  createdAt       DateTime    @default(now())

  org           Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  series        EventSeries?    @relation(fields: [seriesId], references: [id])
  host          User            @relation("EventHost", fields: [hostId], references: [id])
  registrations Registration[]
  reminders     EventReminder[]

  @@index([orgId])
  @@index([startsAt])
}

model Registration {
  id                      String             @id @default(cuid())
  eventId                 String
  userId                  String
  type                    RegistrationType
  status                  RegistrationStatus @default(pending)
  amount                  Int?
  stripeCheckoutSessionId String?            @unique
  stripePaymentIntentId   String?
  checkinToken            String             @unique
  checkedInAt             DateTime?
  waitlistPosition        Int?
  refundedAt              DateTime?
  createdAt               DateTime           @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

model EventReminder {
  id            String    @id @default(cuid())
  eventId       String
  offsetMinutes Int
  channel       String    @default("email")
  scheduledFor  DateTime
  sentAt        DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ─── Academy / cursussen (Fase 6) ───────────────────────────────────────────

enum CourseStatus {
  draft
  published
}

enum QuestionType {
  single
  multiple
  truefalse
}

model Course {
  id          String       @id @default(cuid())
  orgId       String
  title       String
  slug        String       @unique
  description String?
  coverImage  String?
  isPublic    Boolean      @default(false)
  minTier     String?
  status      CourseStatus @default(draft)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  org          Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  modules      CourseModule[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([orgId])
}

model CourseModule {
  id        String @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id                   String  @id @default(cuid())
  courseModuleId       String
  title                String
  content              String
  videoUrl             String?
  durationSec          Int?
  isPreview            Boolean @default(false)
  sortOrder            Int     @default(0)
  dripOffsetDays       Int?
  prerequisiteLessonId String?

  module   CourseModule     @relation(fields: [courseModuleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  quiz     Quiz?

  @@index([courseModuleId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  source     String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Quiz {
  id          String @id @default(cuid())
  lessonId    String @unique
  title       String
  passPercent Int    @default(70)

  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  type      QuestionType @default(single)
  prompt    String
  sortOrder Int          @default(0)

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([quizId])
}

model Answer {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  passed      Boolean
  submittedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

model Certificate {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  serial    String   @unique
  issuedAt  DateTime @default(now())
  pdfUrl    String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

// ─── Chat / DM (Fase 3) ─────────────────────────────────────────────────────

enum ConversationType {
  direct
  group
}

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType @default(direct)
  title       String?
  createdById String?
  createdAt   DateTime         @default(now())

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  conversationId String
  userId         String
  role           String    @default("member")
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime  @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── Content-instroom (Fase 5) ──────────────────────────────────────────────

enum StreamStatus {
  scheduled
  live
  ended
}

enum NewsletterStatus {
  draft
  scheduled
  sent
}

model Livestream {
  id           String       @id @default(cuid())
  orgId        String
  hostId       String
  title        String
  description  String?
  embedUrl     String // YouTube embed URL
  isPublic     Boolean      @default(false)
  minTier      String?
  status       StreamStatus @default(scheduled)
  startsAt     DateTime?
  recordingUrl String?
  createdAt    DateTime     @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  host User         @relation("StreamHost", fields: [hostId], references: [id])

  @@index([orgId])
}

model NewsletterIssue {
  id             String           @id @default(cuid())
  orgId          String
  subject        String
  content        String
  status         NewsletterStatus @default(draft)
  segment        String?
  scheduledFor   DateTime?
  sentAt         DateTime?
  recipientCount Int?
  createdAt      DateTime         @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}
